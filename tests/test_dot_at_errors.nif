(.nif24)
(stmts
  (type :Point (object 
    (fld :x (i +64))
    (fld :y (i +64))
  ))
  
  (proc :test_invalid_dot.0
    (params)
    (result)
    (clobber)
    (stmts
      # Error: trying to use dot on an integer
      (var :notptr.0 (rax) (i +64))
      (mov (rax) +42)
      
      # This should error: can't access field of non-pointer
      (mov (rbx) (mem (dot notptr.0 :x)))
      
      (ret)
    )
  )
  
  (proc :test_invalid_at.0
    (params)
    (result)
    (clobber)
    (stmts
      # Error: trying to use at on non-array/non-aptr
      (var :notarr.0 (rax) (i +64))
      (mov (rax) +42)
      
      # This should error: can't index non-array
      (mov (rbx) (mem (at notarr.0 +0)))
      
      (ret)
    )
  )
  
  (proc :test_wrong_field.0
    (params)
    (result)
    (clobber)
    (stmts
      (var :p (rax) (ptr Point))
      
      # This should error: Point doesn't have field :z
      (mov (rbx) (mem (dot p :z)))
      
      (ret)
    )
  )
  
  (proc :main.0
    (params)
    (result)
    (clobber)
    (stmts
      (mov (rax) +60)
      (mov (rdi) +0)
      (syscall)
    )
  )
)

