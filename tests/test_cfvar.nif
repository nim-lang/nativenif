(.nif24)
(stmts
  (proc :main.0
    (params)
    (result)
    (clobber)
    (stmts
      # Test control flow variable
      (cfvar :tmp.0)
      
      # Set RAX to 0
      (mov (rax) +0)
      
      # Compare RAX with 0
      (cmp (rax) +0)
      
      # If zero, set tmp to true and jump
      (ite (zf)
        (stmts
          (jtrue tmp.0)
        )
        (stmts)
      )
      
      # This should be skipped if jtrue was executed
      (mov (rax) +99)
      
      # Now check cfvar
      (ite tmp.0
        (stmts
          # tmp was set, so RAX should be 0
          (mov (rax) +42)
        )
        (stmts
          # tmp was not set, RAX would be 99
          (mov (rax) +1)
        )
      )
      
      # Exit with status in RAX
      (mov (rdi) (rax))
      (mov (rax) +60)
      (syscall)
    )
  )
)

