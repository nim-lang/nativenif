(.nif24)
(stmts
  (proc :test_param_binding.0
    (params
      (param :x.0 (rax) (i +64))
      (param :y.0 (rbx) (i +64))
    )
    (result)
    (clobber)
    (stmts
      # Parameters are already bound to registers
      # Using the parameter name is OK
      (mov (rcx) x.0)  # ✓ OK: use parameter by name
      
      # ERROR: Cannot use (rax) directly because it's bound to parameter x.0
      (mov (rax) +42)
      
      (mov (rax) +60)
      (syscall)
    )
  )
)

