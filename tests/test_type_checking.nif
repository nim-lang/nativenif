(.nif24)
(stmts
  (proc :main.0
    (params)
    (result)
    (clobber)
    (stmts
      # Valid: integer arithmetic
      (var :x.0 (rax) (i +64))
      (var :y.0 (rbx) (i +64))
      (mov (rax) +10)
      (mov (rbx) +5)
      (add (rax) (rbx))  # OK: i64 + i64
      (sub (rax) (rbx))  # OK: i64 - i64
      
      # Valid: pointer arithmetic with aptr
